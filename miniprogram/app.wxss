page {
  background-color: #f5f6f8;
  color: #1f1f1f;
  font-size: 28rpx;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.btn-primary {
  background: #1677ff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.btn-primary[disabled] {
  background: #91caff;
  color: #fff;
}

.btn-secondary {
  background: #fff;
  color: #1677ff;
  border: 2rpx solid #1677ff;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f6f8;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  background: #f5f6f8;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
}

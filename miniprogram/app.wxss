/* Invento Design System — Apple HIG + 微信 theme.json 变量（真机 DarkMode） */

page {
  background-color: @pageBgColor;
  color: @textPrimary;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'PingFang SC', 'Helvetica Neue', sans-serif;
  line-height: 1.47059;
  letter-spacing: -0.022em;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

.container,
.page {
  min-height: 100vh;
  padding: 0 40rpx 64rpx;
  box-sizing: border-box;
  background-color: @pageBgColor;
}

/* —— Typography —— */
.text-eyebrow {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: @textSecondary;
  margin-bottom: 12rpx;
}

.text-title {
  display: block;
  font-size: 56rpx;
  font-weight: 600;
  letter-spacing: -0.03em;
  line-height: 1.08;
  color: @textPrimary;
}

.text-subtitle {
  display: block;
  font-size: 28rpx;
  color: @textSecondary;
  line-height: 1.5;
  margin-top: 12rpx;
}

.text-section {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: @textSecondary;
  margin: 48rpx 0 20rpx 8rpx;
}

/* —— Surfaces（Apple grouped：页面灰 → 卡片白 → 输入槽灰） —— */
.card {
  background-color: @bgSecondary;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid @cardBorder;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-flat {
  background-color: @bgSecondary;
  border-radius: 20rpx;
  border: 1rpx solid @cardBorder;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-inset {
  background-color: @fillInset;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid @borderSubtle;
  box-shadow: none;
}

/* —— Buttons（用 view，原生 button 无法可靠应用 @accent） —— */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #0071e3;
  border-radius: 980rpx;
  height: 88rpx;
  min-height: 88rpx;
  border: none;
}

.btn-primary .btn-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: -0.01em;
  line-height: 1.2;
}

.btn-primary.is-disabled {
  pointer-events: none;
  opacity: 0.72;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: @bgSecondary;
  border: 2rpx solid @accent;
  border-radius: 980rpx;
  height: 88rpx;
  min-height: 88rpx;
}

.btn-secondary .btn-text {
  color: @accent;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.2;
}

.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: @bgTertiary;
  border: 1rpx solid @borderSubtle;
  border-radius: 980rpx;
  height: 80rpx;
  min-height: 80rpx;
}

.btn-ghost .btn-text {
  color: @textPrimary;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.2;
}

/* 兼容仍使用原生 button 的页面 */
button {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  line-height: 1.2;
  overflow: visible;
}

button::after {
  border: none;
}

/* —— Forms —— */
.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: @textSecondary;
  margin-bottom: 12rpx;
  letter-spacing: 0.02em;
}

/* 输入槽：view 容器承载背景，原生 input 透明（真机更可靠） */
.input-field {
  background-color: @inputBg;
  border: 2rpx solid @inputBorder;
  border-radius: 14rpx;
  overflow: hidden;
}

.textarea-field {
  background-color: @inputBg;
  border: 2rpx solid @inputBorder;
  border-radius: 14rpx;
  overflow: hidden;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 28rpx;
  background-color: transparent;
  border-radius: 0;
  box-sizing: border-box;
  font-size: 30rpx;
  color: @textPrimary;
  border: none;
}

.input-placeholder {
  color: @placeholder;
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 24rpx 28rpx;
  background-color: transparent;
  border-radius: 0;
  box-sizing: border-box;
  font-size: 30rpx;
  color: @textPrimary;
  line-height: 1.5;
  border: none;
}

/* —— Segmented control（iOS 胶囊分段） —— */
.segment {
  display: flex;
  background-color: @segmentTrack;
  border: 2rpx solid @borderSubtle;
  border-radius: 980rpx;
  padding: 6rpx;
  margin-bottom: 40rpx;
}

.segment-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 980rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: @textSecondary;
}

.segment-item.active {
  font-weight: 600;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.16);
  border: 1rpx solid transparent;
}

/* —— Role pills —— */
.role-pill {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: 980rpx;
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 0.01em;
}

.role-pill.manager {
  background: rgba(255, 149, 0, 0.15);
  color: #ff9f0a;
}

.role-pill.recorder {
  background: rgba(52, 199, 89, 0.15);
  color: #30d158;
}

.role-pill.service {
  background: rgba(0, 113, 227, 0.12);
  color: @accent;
}

.role-tag {
  padding: 8rpx 20rpx;
  border-radius: 980rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.role-tag.manager {
  background: rgba(255, 149, 0, 0.15);
  color: #ff9f0a;
}

.role-tag.recorder {
  background: rgba(52, 199, 89, 0.15);
  color: #30d158;
}

.role-tag.service {
  background: rgba(0, 113, 227, 0.12);
  color: @accent;
}

/* —— List rows（iOS Settings） —— */
.list-row {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background-color: @bgSecondary;
  border-bottom: 1rpx solid @borderSubtle;
}

.list-row:last-child {
  border-bottom: none;
}

.list-row:active,
.list-row-active {
  background: @bgTertiary;
}

.list-row-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.list-row-icon.blue { background: rgba(0, 113, 227, 0.12); color: @accent; }
.list-row-icon.green { background: rgba(52, 199, 89, 0.15); color: #30d158; }
.list-row-icon.orange { background: rgba(255, 149, 0, 0.15); color: #ff9f0a; }
.list-row-icon.purple { background: rgba(175, 82, 222, 0.15); color: #bf5af2; }
.list-row-icon.gray { background: @bgTertiary; color: @textSecondary; }

.list-row-body {
  flex: 1;
  min-width: 0;
}

.list-row-title {
  font-size: 30rpx;
  font-weight: 500;
  color: @textPrimary;
  margin-bottom: 4rpx;
}

.list-row-desc {
  font-size: 24rpx;
  color: @textSecondary;
  line-height: 1.4;
}

.list-row-chevron {
  color: @chevron;
  font-size: 36rpx;
  font-weight: 300;
  margin-left: 12rpx;
}

/* —— Empty state —— */
.empty-tip {
  text-align: center;
  color: @textSecondary;
  font-size: 28rpx;
  padding: 96rpx 40rpx;
  line-height: 1.5;
}

/* —— Link —— */
.link {
  color: @accent;
  font-size: 26rpx;
}

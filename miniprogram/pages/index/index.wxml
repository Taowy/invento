<view class="page index-page">
  <!-- Hero -->
  <view class="hero">
    <text class="text-eyebrow">Invento</text>
    <text class="text-title">你好，{{userInfo.nickName}}</text>
    <view class="hero-meta">
      <view class="role-pill {{userInfo.role}}">{{roleLabel}}</view>
    </view>
  </view>

  <!-- 录入员 / 管理者 -->
  <block wx:if="{{canWrite}}">
    <text class="text-section">工作台</text>
    <view class="action-grid">
      <view class="action-tile" bindtap="goSearch" hover-class="action-tile-hover">
        <view class="tile-icon blue">
          <text class="tile-symbol">⌕</text>
        </view>
        <text class="tile-name">查询</text>
        <text class="tile-desc">搜索库存</text>
      </view>
      <view class="action-tile" bindtap="goAdd" hover-class="action-tile-hover">
        <view class="tile-icon green">
          <text class="tile-symbol">+</text>
        </view>
        <text class="tile-name">录入</text>
        <text class="tile-desc">新增货物</text>
      </view>
      <view class="action-tile" bindtap="goEdit" hover-class="action-tile-hover">
        <view class="tile-icon orange">
          <text class="tile-symbol">✎</text>
        </view>
        <text class="tile-name">修改</text>
        <text class="tile-desc">编辑信息</text>
      </view>
      <view class="action-tile" wx:if="{{isManager}}" bindtap="goTeamStats" hover-class="action-tile-hover">
        <view class="tile-icon purple">
          <text class="tile-symbol">◫</text>
        </view>
        <text class="tile-name">团队统计</text>
        <text class="tile-desc">团队数据</text>
      </view>
    </view>

    <text class="text-section" wx:if="{{isManager}}">管理</text>
    <view class="card-flat" wx:if="{{isManager}}">
      <view class="list-row" bindtap="goResetRequests" hover-class="list-row-active">
        <view class="list-row-icon orange">
          <text class="icon-text">⚿</text>
        </view>
        <view class="list-row-body">
          <view class="list-row-title">密码重置</view>
          <view class="list-row-desc">处理用户的忘记密码申请</view>
        </view>
        <view class="badge" wx:if="{{resetCount > 0}}">{{resetCount > 99 ? '99+' : resetCount}}</view>
        <text class="list-row-chevron">›</text>
      </view>
    </view>
  </block>

  <!-- 客服 -->
  <block wx:else>
    <text class="text-section">工作台</text>
    <view class="card-flat">
      <view class="list-row" bindtap="goSearch" hover-class="list-row-active">
        <view class="list-row-icon blue">
          <text class="icon-text">⌕</text>
        </view>
        <view class="list-row-body">
          <view class="list-row-title">搜索货物</view>
          <view class="list-row-desc">按名称查找价格和库存详情</view>
        </view>
        <text class="list-row-chevron">›</text>
      </view>
    </view>
  </block>

  <view class="footer-actions">
    <button class="btn-ghost logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.greeting {
  font-size: 36rpx;
  font-weight: 600;
}

.role-tag {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.role-tag.manager {
  background: #fff7e6;
  color: #d48806;
}

.role-tag.service {
  background: #e6f4ff;
  color: #1677ff;
}

.menu-title {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.menu-content {
  flex: 1;
}

.menu-name {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #999;
}

.arrow {
  font-size: 40rpx;
  color: #ccc;
}

.logout-btn {
  margin-top: 24rpx;
}

.reset-bubble {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  background: #1677ff;
  color: #fff;
  border-radius: 999rpx;
  padding: 20rpx 28rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.35);
  z-index: 100;
}

.reset-bubble-badge {
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background: #ff4d4f;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  padding: 0 8rpx;
  margin-right: 12rpx;
}

.reset-bubble-text {
  font-size: 26rpx;
  font-weight: 500;
}

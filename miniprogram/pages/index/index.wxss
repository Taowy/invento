.index-page {
  padding-top: 24rpx;
}

.hero-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 16rpx 8rpx 32rpx;
}

.hero-text {
  flex: 1;
  min-width: 0;
}

.hero-greeting {
  font-size: 52rpx;
  word-break: break-all;
}

.hero-meta {
  margin-top: 20rpx;
}

.hero-avatar {
  width: 168rpx;
  height: 168rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  overflow: hidden;
  background-color: @bgTertiary;
  border: 2rpx solid @cardBorder;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.08);
}

.hero-role-img {
  width: 100%;
  height: 100%;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.action-tile {
  width: 100%;
  background-color: @bgSecondary;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  border: 1rpx solid @cardBorder;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.action-tile-hover {
  transform: scale(0.98);
  opacity: 0.92;
}

.tile-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.tile-icon.blue { background: rgba(0, 113, 227, 0.12); }
.tile-icon.green { background: rgba(52, 199, 89, 0.15); }
.tile-icon.orange { background: rgba(255, 149, 0, 0.15); }
.tile-icon.purple { background: rgba(175, 82, 222, 0.15); }

.tile-symbol {
  font-size: 32rpx;
  font-weight: 500;
  color: @textPrimary;
}

.tile-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: @textPrimary;
  letter-spacing: -0.02em;
  margin-bottom: 4rpx;
}

.tile-desc {
  display: block;
  font-size: 22rpx;
  color: @textSecondary;
}

.list-row-active {
  background: @bgTertiary;
}

.icon-text {
  font-size: 28rpx;
}

.badge {
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 10rpx;
  background: #ff453a;
  color: #fff;
  border-radius: 980rpx;
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
  margin-right: 8rpx;
}

.footer-actions {
  margin-top: 64rpx;
  padding-bottom: 32rpx;
}

.logout-btn {
  width: 100%;
}

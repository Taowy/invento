.index-page {
  padding-top: 24rpx;
}

.hero {
  padding: 16rpx 8rpx 8rpx;
}

.hero-meta {
  margin-top: 24rpx;
}

/* Action grid — Apple product tile feel */
.action-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.action-tile {
  width: calc(50% - 10rpx);
  background: #ffffff;
  border-radius: 20rpx;
  padding: 36rpx 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.action-tile-hover {
  transform: scale(0.98);
  opacity: 0.92;
}

.tile-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.tile-icon.blue { background: rgba(0, 113, 227, 0.12); }
.tile-icon.green { background: rgba(52, 199, 89, 0.12); }
.tile-icon.orange { background: rgba(255, 149, 0, 0.12); }
.tile-icon.purple { background: rgba(175, 82, 222, 0.12); }

.tile-symbol {
  font-size: 32rpx;
  font-weight: 500;
  color: #1d1d1f;
}

.tile-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
  letter-spacing: -0.02em;
  margin-bottom: 6rpx;
}

.tile-desc {
  display: block;
  font-size: 24rpx;
  color: #86868b;
}

.list-row-active {
  background: #f5f5f7;
}

.icon-text {
  font-size: 28rpx;
}

.badge {
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 10rpx;
  background: #ff3b30;
  color: #fff;
  border-radius: 980rpx;
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
  margin-right: 8rpx;
}

.footer-actions {
  margin-top: 64rpx;
  padding-bottom: 32rpx;
}

.logout-btn {
  width: 100%;
}

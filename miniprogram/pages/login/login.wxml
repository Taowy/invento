<view class="page login-page">
  <!-- Loading -->
  <view class="state-center" wx:if="{{checkingSession}}">
    <view class="spinner"></view>
    <text class="state-text">正在恢复登录状态</text>
  </view>

  <block wx:if="{{!checkingSession}}">
    <!-- Hero -->
    <view class="login-hero">
      <text class="brand">Invento</text>
      <text class="text-title login-title">库存管理</text>
      <text class="text-subtitle">简洁、高效、井井有条</text>
    </view>

    <!-- Login -->
    <view wx:if="{{mode === 'login'}}">
      <view class="segment">
        <view class="segment-item active">登录</view>
        <view class="segment-item" bindtap="switchMode" data-mode="register">注册</view>
      </view>

      <view class="card form-card">
        <view class="form-group">
          <text class="form-label">用户名</text>
          <input class="form-input" placeholder="请输入用户名" value="{{username}}" bindinput="onUsernameInput" />
        </view>
        <view class="form-group">
          <text class="form-label">密码</text>
          <input class="form-input" password placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
        </view>
        <view class="forgot-row">
          <text class="link" bindtap="switchMode" data-mode="forgot">忘记密码？</text>
        </view>
        <button class="btn-primary submit-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="handleLogin">登录</button>
      </view>
    </view>

    <!-- Register -->
    <view wx:if="{{mode === 'register'}}">
      <view class="segment">
        <view class="segment-item" bindtap="switchMode" data-mode="login">登录</view>
        <view class="segment-item active">注册</view>
      </view>

      <view class="card form-card">
        <text class="form-label role-section-label">选择角色</text>
        <view class="role-picker">
          <view
            class="role-tile {{role === 'service' ? 'selected' : ''}}"
            bindtap="selectRole"
            data-role="service"
          >
            <view class="role-avatar-wrap">
              <image class="role-avatar" src="{{roleImages.service}}" mode="aspectFill" />
            </view>
            <text class="role-tile-name">客服</text>
          </view>
          <view
            class="role-tile {{role === 'recorder' ? 'selected' : ''}}"
            bindtap="selectRole"
            data-role="recorder"
          >
            <view class="role-avatar-wrap">
              <image class="role-avatar" src="{{roleImages.recorder}}" mode="aspectFill" />
            </view>
            <text class="role-tile-name">录入员</text>
          </view>
          <view
            class="role-tile {{role === 'manager' ? 'selected' : ''}}"
            bindtap="selectRole"
            data-role="manager"
          >
            <view class="role-avatar-wrap">
              <image class="role-avatar" src="{{roleImages.manager}}" mode="aspectFill" />
            </view>
            <text class="role-tile-name">管理者</text>
          </view>
        </view>

        <view class="form-group">
          <text class="form-label">用户名</text>
          <input class="form-input" placeholder="3-32 位字母、数字或下划线" value="{{username}}" bindinput="onUsernameInput" />
        </view>
        <view class="form-group">
          <text class="form-label">密码</text>
          <input class="form-input" password placeholder="至少 6 位" value="{{password}}" bindinput="onPasswordInput" />
        </view>
        <view class="form-group">
          <text class="form-label">确认密码</text>
          <input class="form-input" password placeholder="再次输入密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
        </view>
        <view class="form-group">
          <text class="form-label">显示昵称（可选）</text>
          <input class="form-input" placeholder="默认同用户名" value="{{nickName}}" bindinput="onNickNameInput" />
        </view>

        <view class="form-group" wx:if="{{role === 'manager'}}">
          <text class="form-label">管理者验证码</text>
          <input class="form-input" password placeholder="向管理员索取" value="{{managerCode}}" bindinput="onManagerCodeInput" />
        </view>

        <button class="btn-primary submit-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="handleRegister">注册并登录</button>
      </view>
    </view>

    <!-- Forgot -->
    <view wx:if="{{mode === 'forgot'}}">
      <view class="card form-card">
        <text class="form-heading">忘记密码</text>
        <text class="text-subtitle forgot-desc">提交申请后，管理者将收到通知并为您重置密码。</text>
        <view class="form-group">
          <text class="form-label">用户名</text>
          <input class="form-input" placeholder="您的登录用户名" value="{{forgotUsername}}" bindinput="onForgotUsernameInput" />
        </view>
        <button class="btn-primary submit-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="handleForgotPassword">提交申请</button>
        <button class="btn-secondary back-btn" bindtap="switchMode" data-mode="login">返回登录</button>
      </view>
    </view>

    <view class="dev-hint" wx:if="{{mode !== 'forgot'}}">
      <text class="dev-hint-text">{{serverUrl}}</text>
    </view>
  </block>
</view>

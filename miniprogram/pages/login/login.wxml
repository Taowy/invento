<view class="container login-page">
  <view class="hero card">
    <view class="logo">Invento</view>
    <view class="title">库存管理系统</view>
    <view class="subtitle">管理者录入 · 客服查询 · 井井有条</view>
  </view>

  <view class="card server-info">
    <view class="section-title">服务器连接</view>
    <view class="hint">当前后端：{{serverUrl}}</view>
    <view class="hint warn">开发阶段请在开发者工具勾选「不校验合法域名」</view>
  </view>

  <view class="card" wx:if="{{!registered}}">
    <view class="section-title">注册账号</view>
    <text class="form-label">你的昵称</text>
    <input class="form-input" placeholder="例如：张三" value="{{nickName}}" bindinput="onNickNameInput" />

    <text class="form-label">选择角色</text>
    <radio-group class="role-group" bindchange="onRoleChange">
      <label class="role-item">
        <radio value="service" checked="{{role === 'service'}}" color="#1677ff" />
        <view>
          <view class="role-name">客服</view>
          <view class="role-desc">查询货物信息、搜索价格</view>
        </view>
      </label>
      <label class="role-item">
        <radio value="manager" checked="{{role === 'manager'}}" color="#1677ff" />
        <view>
          <view class="role-name">管理者</view>
          <view class="role-desc">录入货物图片、信息、价格</view>
        </view>
      </label>
    </radio-group>

    <view wx:if="{{role === 'manager'}}">
      <text class="form-label">管理者验证码</text>
      <input class="form-input" password placeholder="向管理员索取验证码" value="{{managerCode}}" bindinput="onManagerCodeInput" />
    </view>

    <button class="btn-primary register-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="handleRegister">
      注册并进入
    </button>
  </view>

  <view class="card" wx:else>
    <view class="welcome">欢迎回来，{{userInfo.nickName}}</view>
    <view class="role-badge {{userInfo.role}}">
      {{userInfo.role === 'manager' ? '管理者' : '客服'}}
    </view>
    <button class="btn-primary enter-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="enterApp">
      进入 Invento
    </button>
  </view>
</view>

<view class="page login-page">
  <!-- Loading -->
  <view class="state-center" wx:if="{{checkingSession}}">
    <view class="spinner"></view>
    <text class="state-text">正在恢复登录状态</text>
  </view>

  <block wx:if="{{!checkingSession}}">
    <!-- Hero -->
    <view class="login-hero">
      <text class="brand" style="color: {{themeColors.accent}};">Invento</text>
      <text class="text-title login-title">库存管理</text>
      <text class="text-subtitle">简洁、高效、井井有条</text>
    </view>

    <!-- Login -->
    <view wx:if="{{mode === 'login'}}">
      <view class="segment" style="background-color: {{themeColors.segmentTrack}}; border-color: {{themeColors.segmentBorder}};">
        <view
          class="segment-item active"
          style="background-color: {{themeColors.segmentActive}}; color: {{themeColors.segmentActiveText}}; border-color: {{themeColors.segmentBorder}};"
        >登录</view>
        <view
          class="segment-item"
          style="color: {{themeColors.segmentInactiveText}};"
          bindtap="switchMode"
          data-mode="register"
        >注册</view>
      </view>

      <view class="card form-card">
        <view class="form-group">
          <text class="form-label">用户名</text>
          <view class="input-field">
            <input class="form-input" placeholder-class="input-placeholder" placeholder="请输入用户名" value="{{username}}" bindinput="onUsernameInput" />
          </view>
        </view>
        <view class="form-group">
          <text class="form-label">密码</text>
          <view class="input-field">
            <input class="form-input" placeholder-class="input-placeholder" password placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
          </view>
        </view>
        <view class="forgot-row">
          <text class="link" style="color: {{themeColors.accent}};" bindtap="switchMode" data-mode="forgot">忘记密码？</text>
        </view>
        <view
          class="btn-primary submit-btn {{loading ? 'is-disabled' : ''}}"
          style="background-color: {{loading ? themeColors.accentDisabled : themeColors.accent}};"
          bindtap="handleLogin"
        >
          <text class="btn-text" style="color: {{themeColors.accentText}};">{{loading ? '登录中...' : '登录'}}</text>
        </view>
      </view>
    </view>

    <!-- Register -->
    <view wx:if="{{mode === 'register'}}">
      <view class="segment" style="background-color: {{themeColors.segmentTrack}}; border-color: {{themeColors.segmentBorder}};">
        <view
          class="segment-item"
          style="color: {{themeColors.segmentInactiveText}};"
          bindtap="switchMode"
          data-mode="login"
        >登录</view>
        <view
          class="segment-item active"
          style="background-color: {{themeColors.segmentActive}}; color: {{themeColors.segmentActiveText}}; border-color: {{themeColors.segmentBorder}};"
        >注册</view>
      </view>

      <view class="card form-card">
        <text class="form-label role-section-label">选择角色</text>
        <view class="role-picker">
          <view
            class="role-tile"
            style="background-color: {{role === 'service' ? themeColors.roleTileSelectedBg : themeColors.roleTileBg}}; border-color: {{role === 'service' ? themeColors.roleTileSelectedBorder : themeColors.roleTileBorder}}; border-width: {{role === 'service' ? '3rpx' : '2rpx'}};"
            bindtap="selectRole"
            data-role="service"
          >
            <view class="role-avatar-wrap">
              <image class="role-avatar" src="{{roleImages.service}}" mode="aspectFill" />
            </view>
            <text class="role-tile-name" style="color: {{role === 'service' ? themeColors.accent : themeColors.roleName}};">客服</text>
          </view>
          <view
            class="role-tile"
            style="background-color: {{role === 'recorder' ? themeColors.roleTileSelectedBg : themeColors.roleTileBg}}; border-color: {{role === 'recorder' ? themeColors.roleTileSelectedBorder : themeColors.roleTileBorder}}; border-width: {{role === 'recorder' ? '3rpx' : '2rpx'}};"
            bindtap="selectRole"
            data-role="recorder"
          >
            <view class="role-avatar-wrap">
              <image class="role-avatar" src="{{roleImages.recorder}}" mode="aspectFill" />
            </view>
            <text class="role-tile-name" style="color: {{role === 'recorder' ? themeColors.accent : themeColors.roleName}};">录入员</text>
          </view>
          <view
            class="role-tile"
            style="background-color: {{role === 'manager' ? themeColors.roleTileSelectedBg : themeColors.roleTileBg}}; border-color: {{role === 'manager' ? themeColors.roleTileSelectedBorder : themeColors.roleTileBorder}}; border-width: {{role === 'manager' ? '3rpx' : '2rpx'}};"
            bindtap="selectRole"
            data-role="manager"
          >
            <view class="role-avatar-wrap">
              <image class="role-avatar" src="{{roleImages.manager}}" mode="aspectFill" />
            </view>
            <text class="role-tile-name" style="color: {{role === 'manager' ? themeColors.accent : themeColors.roleName}};">管理者</text>
          </view>
        </view>

        <view class="form-group">
          <text class="form-label">用户名</text>
          <view class="input-field">
            <input class="form-input" placeholder-class="input-placeholder" placeholder="3-32 位字母、数字或下划线" value="{{username}}" bindinput="onUsernameInput" />
          </view>
        </view>
        <view class="form-group">
          <text class="form-label">密码</text>
          <view class="input-field">
            <input class="form-input" placeholder-class="input-placeholder" password placeholder="至少 6 位" value="{{password}}" bindinput="onPasswordInput" />
          </view>
        </view>
        <view class="form-group">
          <text class="form-label">确认密码</text>
          <view class="input-field">
            <input class="form-input" placeholder-class="input-placeholder" password placeholder="再次输入密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
          </view>
        </view>
        <view class="form-group">
          <text class="form-label">显示昵称（可选）</text>
          <view class="input-field">
            <input class="form-input" placeholder-class="input-placeholder" placeholder="默认同用户名" value="{{nickName}}" bindinput="onNickNameInput" />
          </view>
        </view>

        <view class="form-group" wx:if="{{role === 'manager'}}">
          <text class="form-label">管理者验证码</text>
          <view class="input-field">
            <input class="form-input" placeholder-class="input-placeholder" password placeholder="向管理员索取" value="{{managerCode}}" bindinput="onManagerCodeInput" />
          </view>
        </view>

        <view
          class="btn-primary submit-btn {{loading ? 'is-disabled' : ''}}"
          style="background-color: {{loading ? themeColors.accentDisabled : themeColors.accent}};"
          bindtap="handleRegister"
        >
          <text class="btn-text" style="color: {{themeColors.accentText}};">{{loading ? '注册中...' : '注册并登录'}}</text>
        </view>
      </view>
    </view>

    <!-- Forgot -->
    <view wx:if="{{mode === 'forgot'}}">
      <view class="card form-card">
        <text class="form-heading">忘记密码</text>
        <text class="text-subtitle forgot-desc">提交申请后，管理者将收到通知并为您重置密码。</text>
        <view class="form-group">
          <text class="form-label">用户名</text>
          <view class="input-field">
            <input class="form-input" placeholder-class="input-placeholder" placeholder="您的登录用户名" value="{{forgotUsername}}" bindinput="onForgotUsernameInput" />
          </view>
        </view>
        <view
          class="btn-primary submit-btn {{loading ? 'is-disabled' : ''}}"
          style="background-color: {{loading ? themeColors.accentDisabled : themeColors.accent}};"
          bindtap="handleForgotPassword"
        >
          <text class="btn-text" style="color: {{themeColors.accentText}};">{{loading ? '提交中...' : '提交申请'}}</text>
        </view>
        <view
          class="btn-secondary back-btn"
          style="border-color: {{themeColors.accent}};"
          bindtap="switchMode"
          data-mode="login"
        >
          <text class="btn-text" style="color: {{themeColors.accent}};">返回登录</text>
        </view>
      </view>
    </view>

    <view class="dev-hint" wx:if="{{mode !== 'forgot'}}">
      <text class="dev-hint-text">{{serverUrl}}</text>
    </view>
  </block>
</view>

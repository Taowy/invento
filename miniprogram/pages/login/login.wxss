.login-page {
  padding-top: 48rpx;
}

.login-hero {
  text-align: center;
  padding: 48rpx 0 56rpx;
}

.brand {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.12em;
  color: #0071e3;
  margin-bottom: 16rpx;
}

.login-title {
  font-size: 64rpx;
}

.form-card {
  padding: 40rpx 36rpx;
}

.form-heading {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  letter-spacing: -0.02em;
  margin-bottom: 12rpx;
}

.forgot-desc {
  margin-bottom: 36rpx;
}

.forgot-row {
  text-align: right;
  margin: -8rpx 0 32rpx;
}

.submit-btn {
  width: 100%;
  margin-top: 8rpx;
}

.back-btn {
  width: 100%;
  margin-top: 20rpx;
}

/* Role picker — 三列方形 MBTI 风格 */
.role-section-label {
  margin-bottom: 20rpx;
}

.role-picker {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.role-tile {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 10rpx 16rpx;
  background: #f5f5f7;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  box-sizing: border-box;
}

.role-tile.selected {
  background: rgba(0, 113, 227, 0.06);
  border-color: #0071e3;
}

.role-avatar-wrap {
  width: 100%;
  height: 0;
  padding-bottom: 100%;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  background: #ffffff;
}

.role-avatar {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.role-tile-name {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #1d1d1f;
  text-align: center;
}

.role-tile.selected .role-tile-name {
  color: #0071e3;
}

.state-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e8e8ed;
  border-top-color: #0071e3;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-text {
  font-size: 28rpx;
  color: #86868b;
}

.dev-hint {
  text-align: center;
  margin-top: 48rpx;
  padding-bottom: 32rpx;
}

.dev-hint-text {
  font-size: 22rpx;
  color: #c7c7cc;
  word-break: break-all;
}

.form-group:last-of-type {
  margin-bottom: 0;
}

.login-page {
  min-height: 100vh;
}

.hero {
  text-align: center;
  padding: 48rpx 32rpx;
}

.logo {
  display: inline-block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1677ff;
  background: linear-gradient(135deg, #e6f4ff 0%, #f6ffed 100%);
  padding: 24rpx 40rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.title {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.subtitle {
  color: #666;
  font-size: 26rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.hint {
  color: #888;
  font-size: 24rpx;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.server-info .hint {
  color: #666;
  margin-bottom: 8rpx;
}

.server-info .warn {
  color: #d48806;
}

.tab-row {
  display: flex;
  margin-bottom: 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: #888;
}

.tab.active {
  color: #1677ff;
  font-weight: 600;
  border-bottom: 4rpx solid #1677ff;
  margin-bottom: -2rpx;
}

.forgot-link {
  text-align: right;
  color: #1677ff;
  font-size: 24rpx;
  margin: 16rpx 0 8rpx;
}

.submit-btn {
  margin-top: 32rpx;
}

.back-btn {
  margin-top: 16rpx;
}

.role-group {
  display: block;
}

.role-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: #f5f6f8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.role-name {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.role-desc {
  font-size: 24rpx;
  color: #888;
}

.loading-card {
  text-align: center;
  padding: 80rpx 32rpx;
}

.loading-text {
  color: #888;
  font-size: 28rpx;
}

.form-label {
  margin-top: 16rpx;
}

.form-label:first-of-type {
  margin-top: 0;
}

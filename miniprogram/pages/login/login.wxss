.login-page {
  padding-top: 48rpx;
}

.login-hero {
  text-align: center;
  padding: 48rpx 0 56rpx;
}

.brand {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.12em;
  color: @accent;
  margin-bottom: 16rpx;
}

.login-title {
  font-size: 64rpx;
}

.form-card {
  padding: 40rpx 36rpx;
}

.form-heading {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  letter-spacing: -0.02em;
  margin-bottom: 12rpx;
  color: @textPrimary;
}

.forgot-desc {
  margin-bottom: 36rpx;
}

.forgot-row {
  text-align: right;
  margin: -8rpx 0 32rpx;
}

.submit-btn {
  width: 100%;
  margin-top: 8rpx;
}

.back-btn {
  width: 100%;
  margin-top: 20rpx;
}

.role-section-label {
  margin-bottom: 20rpx;
}

.role-picker {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.role-tile {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 10rpx 16rpx;
  border-radius: 16rpx;
  border-style: solid;
  box-sizing: border-box;
}

.role-avatar-wrap {
  width: 100%;
  height: 0;
  padding-bottom: 100%;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: @bgSecondary;
  border: 1rpx solid @borderSubtle;
}

.role-avatar {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.role-tile-name {
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  text-align: center;
}

.state-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid @spinnerTrack;
  border-top-color: @accent;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-text {
  font-size: 28rpx;
  color: @textSecondary;
}

.dev-hint {
  text-align: center;
  margin-top: 48rpx;
  padding-bottom: 32rpx;
}

.dev-hint-text {
  font-size: 22rpx;
  color: @textTertiary;
  word-break: break-all;
}

.form-group:last-of-type {
  margin-bottom: 0;
}

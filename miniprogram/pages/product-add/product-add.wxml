<view class="page form-page">
  <view class="form-hero">
    <text class="text-eyebrow">新增</text>
    <text class="text-title form-title">录入货物</text>
  </view>

  <view class="card form-card">
    <text class="form-section-label">图片</text>
    <text class="form-hint">最多 3 张</text>
    <view class="image-list">
      <view class="image-item" wx:for="{{images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" />
        <view class="remove-btn" bindtap="removeImage" data-index="{{index}}">×</view>
      </view>
      <view class="image-add" wx:if="{{images.length < 3}}" bindtap="chooseImage">
        <text class="add-symbol">+</text>
      </view>
    </view>

    <view class="form-divider"></view>

    <view class="form-group">
      <text class="form-label">货物名称</text>
      <input class="form-input" placeholder="例如：A型螺丝 M6" value="{{name}}" bindinput="onNameInput" />
    </view>
    <view class="form-group">
      <text class="form-label">价格（元）</text>
      <input class="form-input" type="digit" placeholder="0.00" value="{{price}}" bindinput="onPriceInput" />
    </view>
    <view class="form-group">
      <text class="form-label">规格 / 型号</text>
      <input class="form-input" placeholder="选填" value="{{spec}}" bindinput="onSpecInput" />
    </view>
    <view class="form-group">
      <text class="form-label">库存数量</text>
      <input class="form-input" type="number" placeholder="0" value="{{stock}}" bindinput="onStockInput" />
    </view>
    <view class="form-group">
      <text class="form-label">备注</text>
      <textarea class="form-textarea" placeholder="补充说明..." value="{{remark}}" bindinput="onRemarkInput" maxlength="500" />
    </view>

    <button class="btn-primary submit-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submit">保存</button>
  </view>
</view>

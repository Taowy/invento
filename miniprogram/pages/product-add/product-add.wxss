.form-page {
  padding-top: 16rpx;
}

.form-hero {
  padding: 8rpx 8rpx 32rpx;
}

.form-title {
  font-size: 48rpx;
}

.form-card {
  padding: 40rpx 36rpx;
}

.form-section-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: #86868b;
  margin-bottom: 8rpx;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: #c7c7cc;
  margin-bottom: 24rpx;
}

.form-divider {
  height: 1rpx;
  background: rgba(0, 0, 0, 0.06);
  margin: 32rpx 0;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 176rpx;
  height: 176rpx;
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.remove-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #1d1d1f;
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 38rpx;
  font-size: 28rpx;
}

.image-add {
  width: 176rpx;
  height: 176rpx;
  border-radius: 16rpx;
  background: #f5f5f7;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-symbol {
  font-size: 48rpx;
  color: #86868b;
  font-weight: 300;
}

.submit-btn {
  width: 100%;
  margin-top: 16rpx;
}

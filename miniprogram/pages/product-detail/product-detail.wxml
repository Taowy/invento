<view class="page detail-page" wx:if="{{product}}">
  <swiper class="hero-gallery" indicator-dots indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#ffffff" autoplay circular wx:if="{{product.images.length}}">
    <swiper-item wx:for="{{product.images}}" wx:key="*this">
      <image class="hero-image" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" />
    </swiper-item>
  </swiper>
  <view class="hero-gallery hero-empty" wx:else>
    <text class="hero-empty-text">暂无图片</text>
  </view>

  <view class="detail-content">
    <text class="detail-name">{{product.name}}</text>
    <text class="detail-price">¥{{product.price}}</text>

    <view class="spec-sheet">
      <view class="spec-row" wx:if="{{product.spec}}">
        <text class="spec-label">规格</text>
        <text class="spec-value">{{product.spec}}</text>
      </view>
      <view class="spec-row">
        <text class="spec-label">库存</text>
        <text class="spec-value">{{product.stock}}</text>
      </view>
      <view class="spec-row" wx:if="{{product.remark}}">
        <text class="spec-label">备注</text>
        <text class="spec-value">{{product.remark}}</text>
      </view>
      <view class="spec-row spec-row-last">
        <text class="spec-label">录入人</text>
        <text class="spec-value">{{product.creatorName || '—'}}</text>
      </view>
    </view>

    <view
      wx:if="{{canEdit}}"
      class="btn-primary edit-btn"
      style="background-color: {{themeColors.accent}};"
      bindtap="goEdit"
    >
      <text class="btn-text" style="color: {{themeColors.accentText}};">修改货物</text>
    </view>
  </view>
</view>

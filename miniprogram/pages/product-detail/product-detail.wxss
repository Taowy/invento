.detail-page {
  padding: 0;
  min-height: 100vh;
  background-color: @pageBgColor;
}

.hero-gallery {
  width: 100%;
  height: 560rpx;
  background: @bgTertiary;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-empty {
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-empty-text {
  font-size: 28rpx;
  color: @textSecondary;
}

.detail-content {
  padding: 48rpx 40rpx 64rpx;
  margin-top: -32rpx;
  background: @pageBgColor;
  border-radius: 32rpx 32rpx 0 0;
  position: relative;
}

.detail-name {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  letter-spacing: -0.03em;
  line-height: 1.15;
  color: @textPrimary;
  margin-bottom: 16rpx;
}

.detail-price {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: @textPrimary;
  margin-bottom: 40rpx;
}

.spec-sheet {
  background-color: @bgSecondary;
  border-radius: 20rpx;
  border: 1rpx solid @cardBorder;
  overflow: hidden;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.spec-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid @borderSubtle;
}

.spec-row-last {
  border-bottom: none;
}

.spec-label {
  font-size: 28rpx;
  color: @textSecondary;
  flex-shrink: 0;
  width: 140rpx;
}

.spec-value {
  font-size: 28rpx;
  color: @textPrimary;
  text-align: right;
  flex: 1;
  word-break: break-all;
}

.edit-btn {
  width: 100%;
}

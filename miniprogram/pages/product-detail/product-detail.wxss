.banner {
  width: 100%;
  height: 500rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.banner image {
  width: 100%;
  height: 100%;
}

.banner-empty {
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #bbb;
}

.name {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.price {
  color: #f5222d;
  font-size: 44rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
}

.row {
  display: flex;
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.label {
  width: 120rpx;
  color: #888;
  flex-shrink: 0;
}

.value {
  flex: 1;
  word-break: break-all;
}

.edit-btn {
  margin-top: 24rpx;
}

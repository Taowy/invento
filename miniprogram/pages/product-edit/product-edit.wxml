<view class="page form-page" wx:if="{{!loading}}">
  <view class="form-hero">
    <text class="text-eyebrow">编辑</text>
    <text class="text-title form-title">修改货物</text>
  </view>

  <view class="card form-card">
    <text class="form-section-label">图片</text>
    <view class="image-list">
      <view class="image-item" wx:for="{{images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" />
        <view class="remove-btn" bindtap="removeImage" data-index="{{index}}">×</view>
      </view>
      <view class="image-add" wx:if="{{images.length < 3}}" bindtap="chooseImage">
        <text class="add-symbol">+</text>
      </view>
    </view>

    <view class="form-divider"></view>

    <view class="form-group">
      <text class="form-label">货物名称</text>
      <view class="input-field">
        <input class="form-input" placeholder-class="input-placeholder" placeholder="货物名称" value="{{name}}" bindinput="onNameInput" />
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">价格（元）</text>
      <view class="input-field">
        <input class="form-input" placeholder-class="input-placeholder" type="digit" placeholder="0.00" value="{{price}}" bindinput="onPriceInput" />
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">规格 / 型号</text>
      <view class="input-field">
        <input class="form-input" placeholder-class="input-placeholder" placeholder="选填" value="{{spec}}" bindinput="onSpecInput" />
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">库存数量</text>
      <view class="input-field">
        <input class="form-input" placeholder-class="input-placeholder" type="number" placeholder="0" value="{{stock}}" bindinput="onStockInput" />
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">备注</text>
      <view class="textarea-field">
        <textarea class="form-textarea" placeholder-class="input-placeholder" placeholder="补充说明..." value="{{remark}}" bindinput="onRemarkInput" maxlength="500" />
      </view>
    </view>

    <view
      class="btn-primary submit-btn {{submitting ? 'is-disabled' : ''}}"
      style="background-color: {{submitting ? themeColors.accentDisabled : themeColors.accent}};"
      bindtap="submit"
    >
      <text class="btn-text" style="color: {{themeColors.accentText}};">{{submitting ? '保存中...' : '保存修改'}}</text>
    </view>
  </view>
</view>

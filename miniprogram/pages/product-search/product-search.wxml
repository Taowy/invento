<view class="page search-page">
  <view class="search-hero">
    <text class="text-title search-title">{{editMode ? '修改货物' : '查询货物'}}</text>
    <text class="text-subtitle" wx:if="{{editMode}}">搜索并选择要编辑的项目</text>
  </view>

  <view class="search-pill">
    <text class="search-icon">⌕</text>
    <input
      class="search-input"
      placeholder="搜索货物名称..."
      placeholder-class="search-placeholder"
      value="{{keyword}}"
      bindinput="onKeywordInput"
      confirm-type="search"
      bindconfirm="doSearch"
    />
  </view>

  <view class="result-meta" wx:if="{{searched}}">
    <text class="result-count">{{list.length}} 个结果</text>
  </view>

  <view wx:if="{{list.length === 0 && searched}}" class="empty-state">
    <text class="empty-icon">⌕</text>
    <text class="empty-title">未找到货物</text>
    <text class="empty-desc">试试其他关键词，或检查拼写</text>
  </view>

  <view class="product-list">
    <view class="product-row" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}" hover-class="product-row-hover">
      <image wx:if="{{item.images[0]}}" class="product-thumb" src="{{item.images[0]}}" mode="aspectFill" />
      <view wx:else class="product-thumb product-thumb-empty">
        <text>—</text>
      </view>
      <view class="product-body">
        <text class="product-name">{{item.name}}</text>
        <text class="product-price">¥{{item.price}}</text>
        <view class="product-meta">
          <text wx:if="{{item.spec}}">{{item.spec}}</text>
          <text class="meta-dot" wx:if="{{item.spec}}">·</text>
          <text>库存 {{item.stock}}</text>
        </view>
      </view>
      <text class="list-row-chevron">›</text>
    </view>
  </view>
</view>

.search-page {
  padding-top: 16rpx;
}

.search-hero {
  padding: 8rpx 8rpx 32rpx;
}

.search-title {
  font-size: 48rpx;
}

.search-pill {
  display: flex;
  align-items: center;
  background-color: @inputBg;
  border: 2rpx solid @inputBorder;
  border-radius: 980rpx;
  padding: 0 28rpx;
  height: 80rpx;
  margin-bottom: 32rpx;
}

.search-icon {
  font-size: 32rpx;
  color: @textSecondary;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  font-size: 30rpx;
  color: @textPrimary;
}

.result-meta {
  padding: 0 8rpx 20rpx;
}

.result-count {
  font-size: 24rpx;
  color: @textSecondary;
  font-weight: 500;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.product-row {
  display: flex;
  align-items: center;
  background-color: @bgSecondary;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid @cardBorder;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.product-row-hover {
  background-color: @bgTertiary;
}

.product-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background-color: @fillInset;
  border: 1rpx solid @borderSubtle;
}

.product-thumb-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: @textTertiary;
  font-size: 28rpx;
}

.product-body {
  flex: 1;
  min-width: 0;
  padding: 0 20rpx;
}

.product-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: @textPrimary;
  letter-spacing: -0.02em;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: @textPrimary;
  margin-bottom: 8rpx;
}

.product-meta {
  font-size: 24rpx;
  color: @textSecondary;
}

.meta-dot {
  margin: 0 8rpx;
}

.empty-state {
  text-align: center;
  padding: 96rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 64rpx;
  color: @textTertiary;
  margin-bottom: 24rpx;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: @textPrimary;
  margin-bottom: 12rpx;
}

.empty-desc {
  display: block;
  font-size: 26rpx;
  color: @textSecondary;
}

<view class="page reset-page">
  <view class="reset-hero">
    <text class="text-eyebrow">Admin</text>
    <text class="text-title reset-title">密码重置</text>
    <text class="text-subtitle">处理用户的忘记密码申请</text>
  </view>

  <view class="empty-state" wx:if="{{!loading && list.length === 0}}">
    <text class="empty-title">暂无申请</text>
    <text class="empty-desc">待处理的密码重置请求将显示在此</text>
  </view>

  <view class="request-card {{selectedId === item.id ? 'selected' : ''}}"
    wx:for="{{list}}" wx:key="id"
    bindtap="selectRequest" data-id="{{item.id}}">
    <view class="request-top">
      <view>
        <text class="request-name">{{item.nickName}}</text>
        <text class="request-user">@{{item.username}}</text>
      </view>
      <view class="role-pill {{item.role}}">{{item.role === 'manager' ? '管理者' : (item.role === 'recorder' ? '录入员' : '客服')}}</view>
    </view>
    <text class="request-time">{{item.requestedAtText}}</text>
  </view>

  <view class="card form-card" wx:if="{{selectedId}}">
    <text class="form-heading">设置新密码</text>
    <view class="form-group">
      <text class="form-label">新密码</text>
      <view class="input-field">
        <input class="form-input" placeholder-class="input-placeholder" password placeholder="至少 6 位" value="{{newPassword}}" bindinput="onNewPasswordInput" />
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">确认密码</text>
      <view class="input-field">
        <input class="form-input" placeholder-class="input-placeholder" password placeholder="再次输入" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
      </view>
    </view>
    <view
      class="btn-primary submit-btn {{submitting ? 'is-disabled' : ''}}"
      style="background-color: {{submitting ? themeColors.accentDisabled : themeColors.accent}};"
      bindtap="submitReset"
    >
      <text class="btn-text" style="color: {{themeColors.accentText}};">{{submitting ? '提交中...' : '确认重置'}}</text>
    </view>
  </view>
</view>

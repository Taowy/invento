.reset-page {
  padding-top: 16rpx;
}

.reset-hero {
  padding: 8rpx 8rpx 40rpx;
}

.reset-title {
  font-size: 48rpx;
}

.request-card {
  background-color: @bgSecondary;
  border-radius: 20rpx;
  padding: 32rpx 36rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid @cardBorder;
}

.request-card.selected {
  border-color: @accent;
  background: @accentSurface;
}

.request-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.request-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: @textPrimary;
  margin-bottom: 4rpx;
}

.request-user {
  display: block;
  font-size: 24rpx;
  color: @textSecondary;
}

.request-time {
  font-size: 24rpx;
  color: @textSecondary;
}

.form-card {
  padding: 40rpx 36rpx;
  margin-top: 24rpx;
}

.form-heading {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
  color: @textPrimary;
}

.submit-btn {
  width: 100%;
  margin-top: 8rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: @textPrimary;
  margin-bottom: 12rpx;
}

.empty-desc {
  display: block;
  font-size: 26rpx;
  color: @textSecondary;
}

.intro-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.intro-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
}

.stat-item {
  padding-bottom: 24rpx;
}

.stat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.stat-name {
  font-size: 30rpx;
  font-weight: 500;
}

.role-tag {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.role-tag.manager {
  background: #fff7e6;
  color: #d48806;
}

.role-tag.recorder {
  background: #f6ffed;
  color: #389e0d;
}

.role-tag.service {
  background: #e6f4ff;
  color: #1677ff;
}

.stat-grid {
  display: flex;
  gap: 16rpx;
}

.stat-cell {
  flex: 1;
  background: #f5f6f8;
  border-radius: 12rpx;
  padding: 20rpx 0;
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 600;
  color: #1677ff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #888;
}

.stats-page {
  padding-top: 16rpx;
}

.stats-hero {
  padding: 8rpx 8rpx 40rpx;
}

.stats-title {
  font-size: 48rpx;
}

.stat-card {
  background-color: @bgSecondary;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid @cardBorder;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.stat-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.stat-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: @textPrimary;
  letter-spacing: -0.02em;
  margin-bottom: 4rpx;
}

.stat-username {
  display: block;
  font-size: 24rpx;
  color: @textSecondary;
}

.stat-metrics {
  display: flex;
  align-items: center;
  background-color: @fillInset;
  border: 1rpx solid @borderSubtle;
  border-radius: 16rpx;
  padding: 28rpx 0;
}

.metric {
  flex: 1;
  text-align: center;
}

.metric-value {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: @textPrimary;
  letter-spacing: -0.02em;
  margin-bottom: 8rpx;
}

.metric-label {
  display: block;
  font-size: 22rpx;
  color: @textSecondary;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.metric-divider {
  width: 1rpx;
  height: 48rpx;
  background: @borderHairline;
}

.empty-state {
  text-align: center;
  padding: 96rpx 40rpx;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: @textPrimary;
  margin-bottom: 12rpx;
}

.empty-desc {
  display: block;
  font-size: 26rpx;
  color: @textSecondary;
}

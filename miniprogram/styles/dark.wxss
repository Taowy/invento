/* Apple-style Dark Mode — 跟随系统 prefers-color-scheme */

@media (prefers-color-scheme: dark) {
  page {
    background-color: #000000;
    color: #f5f5f7;
  }

  /* Typography */
  .text-title { color: #f5f5f7; }
  .text-subtitle,
  .text-eyebrow,
  .text-section { color: #98989d; }

  /* Surfaces */
  .card,
  .card-flat {
    background: #1c1c1e;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }

  .card-inset {
    background: #2c2c2e;
  }

  /* Buttons */
  .btn-primary {
    background: #0a84ff;
  }

  .btn-primary[disabled] {
    background: rgba(10, 132, 255, 0.4);
  }

  .btn-secondary {
    color: #0a84ff;
    border-color: rgba(10, 132, 255, 0.45);
  }

  .btn-ghost {
    background: #2c2c2e;
    color: #f5f5f7;
  }

  /* Forms */
  .form-label { color: #98989d; }

  .form-input,
  .form-textarea {
    background: #2c2c2e;
    color: #f5f5f7;
    border-color: rgba(255, 255, 255, 0.06);
  }

  /* Segmented control */
  .segment {
    background: #2c2c2e;
  }

  .segment-item {
    color: #98989d;
  }

  .segment-item.active {
    background: #636366;
    color: #f5f5f7;
    box-shadow: none;
  }

  /* Role badges */
  .role-pill.manager,
  .role-tag.manager {
    background: rgba(255, 159, 10, 0.18);
    color: #ff9f0a;
  }

  .role-pill.recorder,
  .role-tag.recorder {
    background: rgba(48, 209, 88, 0.18);
    color: #30d158;
  }

  .role-pill.service,
  .role-tag.service {
    background: rgba(10, 132, 255, 0.18);
    color: #0a84ff;
  }

  /* List rows */
  .list-row {
    background: #1c1c1e;
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }

  .list-row:active,
  .list-row-active {
    background: #2c2c2e;
  }

  .list-row-icon.gray {
    background: #2c2c2e;
    color: #98989d;
  }

  .list-row-title { color: #f5f5f7; }
  .list-row-desc { color: #98989d; }
  .list-row-chevron { color: #636366; }

  .link { color: #0a84ff; }

  /* —— Index —— */
  .action-tile {
    background: #1c1c1e;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }

  .tile-symbol,
  .tile-name { color: #f5f5f7; }

  .tile-desc { color: #98989d; }

  /* —— Login —— */
  .brand { color: #0a84ff; }

  .role-tile {
    background: #2c2c2e;
    border-color: transparent;
  }

  .role-tile.selected {
    background: rgba(10, 132, 255, 0.12);
    border-color: #0a84ff;
  }

  .role-avatar-wrap {
    background: #1c1c1e;
  }

  .role-tile-name { color: #f5f5f7; }

  .role-tile.selected .role-tile-name {
    color: #0a84ff;
  }

  .spinner {
    border-color: #3a3a3c;
    border-top-color: #0a84ff;
  }

  .state-text,
  .dev-hint-text { color: #636366; }

  .form-heading { color: #f5f5f7; }

  /* —— Search —— */
  .search-pill {
    background: #2c2c2e;
  }

  .search-input { color: #f5f5f7; }

  .product-row {
    background: #1c1c1e;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .product-row-hover {
    background: #2c2c2e;
  }

  .product-thumb {
    background: #2c2c2e;
  }

  .product-name,
  .product-price,
  .empty-title { color: #f5f5f7; }

  .product-meta,
  .result-count,
  .empty-desc,
  .empty-icon { color: #98989d; }

  /* —— Detail —— */
  .hero-gallery {
    background: #1c1c1e;
  }

  .detail-content {
    background: #000000;
  }

  .detail-name,
  .detail-price { color: #f5f5f7; }

  .spec-sheet {
    background: #1c1c1e;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .spec-row {
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }

  .spec-label { color: #98989d; }
  .spec-value { color: #f5f5f7; }

  /* —— Form pages (add/edit) —— */
  .form-section-label { color: #98989d; }
  .form-hint { color: #636366; }

  .form-divider {
    background: rgba(255, 255, 255, 0.08);
  }

  .image-add {
    background: #2c2c2e;
  }

  .add-symbol { color: #98989d; }

  .remove-btn {
    background: #636366;
  }

  /* —— Team stats —— */
  .stat-card {
    background: #1c1c1e;
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: none;
  }

  .stat-name,
  .metric-value { color: #f5f5f7; }

  .stat-username,
  .metric-label { color: #98989d; }

  .stat-metrics {
    background: #2c2c2e;
  }

  .metric-divider {
    background: rgba(255, 255, 255, 0.1);
  }

  /* —— Reset requests —— */
  .request-card {
    background: #1c1c1e;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .request-card.selected {
    border-color: #0a84ff;
    background: rgba(10, 132, 255, 0.1);
  }

  .request-name { color: #f5f5f7; }
  .request-user,
  .request-time { color: #98989d; }
}

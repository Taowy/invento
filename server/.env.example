# ========== 服务器 ==========
PORT=3000
# 填入你的 ECS 公网 IP，小程序 config.js 里也要填同一个
ECS_PUBLIC_IP=47.96.99.224

# ========== 微信小程序 ==========
WX_APPID=你的小程序AppID
WX_SECRET=你的小程序AppSecret

# ========== 安全 ==========
JWT_SECRET=请改成随机长字符串
# 管理者注册验证码（内部团队使用）
MANAGER_CODE=invento2024

# ========== MySQL ==========
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的数据库密码
DB_NAME=invento

# ========== 阿里云 OSS ==========
OSS_ENABLED=true
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=invento-photo
# 绑定的 CNAME 域名（HTTPS），用于小程序展示图片
OSS_CUSTOM_DOMAIN=https://invento-photo.cn-hangzhou.taihangtop.cn
# ECS 同地域建议用内网；本地开发可注释掉此行
OSS_ENDPOINT=oss-cn-hangzhou-internal.aliyuncs.com
OSS_ACCESS_KEY_ID=你的AccessKeyId
OSS_ACCESS_KEY_SECRET=你的AccessKeySecret
